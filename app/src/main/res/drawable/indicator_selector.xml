<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Estado Seleccionado (Punto Blanco Brillante con Borde Negro) -->
    <item android:state_selected="true">
        <layer-list>
            <item android:gravity="center">
                <shape android:shape="oval">
                    <!-- Borde negro para contraste -->
                    <stroke android:width="1dp" android:color="#000000"/>
                    <solid android:color="@android:color/white"/>
                    <size android:width="12dp" android:height="12dp"/>
                </shape>
            </item>
        </layer-list>
    </item>

    <!-- Estado Normal (Punto Blanco Semitransparente con Borde) -->
    <item>
        <layer-list>
            <item android:gravity="center">
                <shape android:shape="oval">
                    <!-- Borde oscuro sutil -->
                    <stroke android:width="1dp" android:color="#40000000"/>
                    <solid android:color="#B3FFFFFF"/> <!-- Blanco más visible (70% opacidad) -->
                    <size android:width="8dp" android:height="8dp"/>
                </shape>
            </item>
        </layer-list>
    </item>
</selector>