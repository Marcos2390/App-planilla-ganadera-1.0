<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.PlanillaRural" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">#6200EE</item>
        <item name="colorPrimaryDark">#3700B3</item>
        <item name="colorAccent">#03DAC5</item>
        <item name="android:windowBackground">@drawable/pasto</item>
    </style>

    <!-- Estilo de pestañas aumentado a 10sp y forzado a una sola línea -->
    <style name="CustomTabTextAppearance" parent="TextAppearance.Design.Tab">
        <item name="android:textSize">10sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:maxLines">1</item>
    </style>

    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@drawable/pasto</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/imagen</item>
        <item name="postSplashScreenTheme">@style/Theme.PlanillaRural</item>
    </style>

</resources>