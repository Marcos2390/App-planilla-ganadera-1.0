<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Barra de Datos (Transparente) -->
    <LinearLayout
        android:id="@+id/barraHerramientasDatos"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="4dp"
        android:weightSum="100"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btnSNIG"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="50"
            android:text="SNIG"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/rounded_corner_background"
            android:backgroundTint="#00796B"
            android:gravity="center"
            android:paddingVertical="10dp"
            android:layout_margin="2dp" />

        <TextView
            android:id="@+id/btnImportarFragment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="25"
            android:text="Importar"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_corner_background"
            android:backgroundTint="#1976D2"
            android:gravity="center"
            android:layout_margin="2dp" />

        <TextView
            android:id="@+id/btnExportarFragment"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="25"
            android:text="Exportar"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/rounded_corner_background"
            android:backgroundTint="#388E3C"
            android:gravity="center"
            android:layout_margin="2dp" />
    </LinearLayout>

    <SearchView
        android:id="@+id/searchViewAnimales"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:queryHint="Buscar caravana..."
        android:iconifiedByDefault="false"
        android:background="#DDFFFFFF" 
        android:layout_margin="8dp"
        android:elevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/barraHerramientasDatos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- RecyclerView Transparente -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAnimales"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="4dp"
        android:padding="4dp"
        android:clipToPadding="false"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/searchViewAnimales"
        app:layout_constraintBottom_toTopOf="@id/tvResumenCategorias"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvResumenCategorias"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#AA333333" 
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>