<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ListaAnimalesActivity">

    <!-- 1. PESTAÑAS SUPERIORES -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayoutIndicator"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:tabMode="fixed"
        app:tabGravity="fill"
        app:tabMinWidth="0dp"
        app:tabMaxWidth="0dp"
        app:tabPaddingStart="0dp"
        app:tabPaddingEnd="0dp"
        app:tabTextAppearance="@style/CustomTabTextAppearance"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 2. BARRA DE ACCIONES HORIZONTAL -->
    <HorizontalScrollView
        android:id="@+id/barraAccionesHorizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#AAFFFFFF"
        android:scrollbars="none"
        android:elevation="2dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/tabLayoutIndicator">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:gravity="center_vertical">

            <TextView android:id="@+id/btnAgregarAnimal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Agregar" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_add_animal_final" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            <TextView android:id="@+id/btnRegistrarMovimiento" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Movimiento" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_movimiento_final" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            <TextView android:id="@+id/btnSanidadPanel" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Sanidad" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_nav_sanidad" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            <TextView android:id="@+id/btnGestionOvinos" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ovinos" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_add_ovino_final" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            <TextView android:id="@+id/btnGestionPotreros" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Potreros" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_potreros_final" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            <TextView android:id="@+id/btnFinanzas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Finanzas" android:textSize="9sp" android:textStyle="bold" android:drawableTop="@drawable/ic_nav_finanzas" android:padding="8dp" android:gravity="center" android:textColor="#333333"/>
            
            <!-- Botón Nacidos con Burbuja (!) MUY ARRIBA -->
            <FrameLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:clipToPadding="false">
                <TextView 
                    android:id="@+id/btnNacimientos" 
                    android:layout_width="wrap_content" 
                    android:layout_height="wrap_content" 
                    android:text="Nacidos" 
                    android:textSize="9sp" 
                    android:textStyle="bold" 
                    android:drawableTop="@drawable/ic_add_calf_final" 
                    android:padding="8dp" 
                    android:gravity="center" 
                    android:textColor="#333333"/>
                <!-- Burbuja Roja con Símbolo de Exclamación: Se usa margen negativo para subirla -->
                <TextView
                    android:id="@+id/badgeNacimientos"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="-4dp"
                    android:layout_marginEnd="4dp"
                    android:text="!"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:background="@drawable/rounded_corner_background"
                    android:backgroundTint="#FF0000"
                    android:elevation="4dp"
                    android:visibility="gone" />
            </FrameLayout>

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPagerPrincipal"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/barraAccionesHorizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>